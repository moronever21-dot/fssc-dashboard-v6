{
    "$schema": "https://app.kilo.ai/config.json",
    "mcpServers": {
        "google-workspace": {
            "type": "local",
            "command": "npx",
            "args": ["-y", "@taylorwilsdon/google-workspace-mcp@latest"],
            "env": {
                "GOOGLE_CLIENT_ID": "<TU_CLIENT_ID>",
                "GOOGLE_CLIENT_SECRET": "<TU_CLIENT_SECRET>"
            },
            "enabled": true
        }
    }
}