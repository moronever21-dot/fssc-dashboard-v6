# Google OAuth Client ID
# Obtener en: https://console.cloud.google.com/apis/credentials
# Agregar origen autorizado: http://localhost:5173 (dev) y tu dominio de producción
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# IDs de carpetas de Google Drive
# Obtener de la URL de la carpeta: https://drive.google.com/drive/folders/FOLDER_ID
VITE_DRIVE_FOLDER_AUTO_ID=your-fssc-automatizacion-folder-id
VITE_DRIVE_FOLDER_IG_ID=your-fssc-ig-au-2026-folder-id

# Nombre de la empresa (aparece en el dashboard)
VITE_EMPRESA=INGAMA
